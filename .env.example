# ── 服务器地址 ──────────────────────────────────────────────
# 监听地址（推荐通过反向代理访问，仅绑定 localhost）
APP_ADDR=127.0.0.1:3000

# 对外可访问的 Base URL（用于生成二维码、邮件链接等）
# 如使用 Caddy/Nginx 反向代理，填写实际的公网 HTTPS 地址
APP_BASE_URL=https://example.com

# ── 直连 TLS（不使用反向代理时可选）───────────────────────
# HTTP → HTTPS 重定向监听地址（仅启用 TLS 时有效）
# APP_HTTP_REDIRECT_ADDR=:80

# ── 管理员 ──────────────────────────────────────────────────
# 后台登录密码（首次启动后建议在 Web 界面修改）
ADMIN_PASSWORD=change-me

# ── 文件存储目录 ─────────────────────────────────────────────
# 运行时数据（仅 SQLite 数据库）
DATA_DIR=./data

# 课程材料、题库、作业提交等结构化存储根目录
METADATA_DIR=./metadata

# ── TLS 证书 ─────────────────────────────────────────────────
# 手动证书路径（目录下需有 cert.pem / key.pem）
# CERT_PATH=./certs

# Let's Encrypt 自动签发（需要公网域名）
# AUTOCERT_ENABLE=true
# AUTOCERT_HOSTS=example.com
# AUTOCERT_EMAIL=you@example.com
# AUTOCERT_CACHE_DIR=./data/autocert

# ── AI 功能 ──────────────────────────────────────────────────
# 兼容 OpenAI 接口的端点
AI_ENDPOINT=https://api.openai.com/v1

# API 密钥
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 使用的模型名称
AI_MODEL=gpt-4o
